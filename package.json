{
    "name": "bump-updated",
    "version": "3.0.0",
    "description": "Will bump any workspace packages updated since the last git tag, sync workspace packages, npm publish any updated workspace packages and git tag the new release.",
    "keywords": [
        "bump",
        "sync",
        "workspaces",
        "package.json",
        "versioning"
    ],
    "author": "Futago-za Ryuu <futagoza.ryuu@gmail.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/futagoza/bump-updated.git"
    },
    "type": "module",
    "main": "index.js",
    "bin": "bin/bump-updated.js",
    "dependencies": {
        "@futagoza/child-process": "2.0.2",
        "@clack/prompts": "1.7.0",
        "@manypkg/get-packages": "3.1.0",
        "dateformat": "5.0.3",
        "json-parse-even-better-errors": "6.0.0",
        "picomatch": "4.0.5",
        "semver": "7.8.5",
        "yoctocolors": "2.1.2",
        "upath": "3.0.8"
    },
    "devDependencies": {
        "@futagoza/eslint-config": "17.1.0",
        "eslint": "10.7.0"
    },
    "scripts": {
        "bump": "node bin/bump-updated.js --debug",
        "bump:major": "node bin/bump-updated.js --debug -v major",
        "bump:minor": "node bin/bump-updated.js --debug -v minor",
        "bump:patch": "node bin/bump-updated.js --debug -v patch",
        "preview": "node bin/bump-updated.js --debug --dry",
        "test": "eslint"
    },
    "engines": {
        "node": ">= 20"
    },
    "files": [
        "lib",
        "CHANGELOG.md"
    ],
    "license": "MIT"
}
